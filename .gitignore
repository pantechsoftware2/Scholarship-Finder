# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
package-lock.json
/frontend/package-lock.json
/wildfire/package-lock.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
**/.next/

# production
/build
**/build/
dist/
**/dist/

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
**/.env
**/.env.*
!.env.example
!**/.env.example

# python
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# vercel
.vercel
**/.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts
